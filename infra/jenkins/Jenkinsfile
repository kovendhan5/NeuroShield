pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    environment {
        APP_NAME = 'neuroshield-microservice'
        MICROSERVICE_URL = 'http://neuroshield-microservice:5000'
        NEUROSHIELD_API = 'http://neuroshield-orchestrator:8000'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "🔍 Pipeline starting..."
                }
            }
        }

        stage('Build') {
            steps {
                sh '''
                    echo "Building Docker image..."
                    docker build -f apps/Dockerfile.microservice \
                        -t ${APP_NAME}:${BUILD_NUMBER} . || true
                    echo "Build completed"
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    echo "Deploying application..."
                    docker restart neuroshield-microservice || true
                    sleep 3
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    set +e
                    for i in {1..30}; do
                        if curl -f ${MICROSERVICE_URL}/health > /dev/null 2>&1; then
                            echo "✅ Service is healthy"
                            exit 0
                        fi
                        sleep 2
                    done
                    echo "❌ Health check failed"
                    exit 1
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Build succeeded"
        }
        failure {
            echo "❌ Build failed - triggering AI healing"
            sh '''
                curl -X POST ${NEUROSHIELD_API}/api/heal \
                    -H "Content-Type: application/json" \
                    -d '{"reason":"jenkins_build_failed"}' || true
            '''
        }
    }
}
