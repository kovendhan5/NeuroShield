# NeuroShield Environment Configuration
# Copy this to .env: Copy-Item .env.example .env
# Jenkins runs via Docker: docker compose up -d
# Get API token: http://localhost:8080/user/admin/configure

JENKINS_URL=http://localhost:8080
JENKINS_USERNAME=admin
JENKINS_PASSWORD=your-jenkins-password-here
JENKINS_TOKEN=your-jenkins-api-token-here
JENKINS_JOB=build-pipeline
DUMMY_APP_URL=http://localhost:5000
PROMETHEUS_URL=http://localhost:9090
K8S_NAMESPACE=default
AFFECTED_SERVICE=dummy-app
SCALE_REPLICAS=2
POLL_INTERVAL=15
TELEMETRY_OUTPUT_PATH=data/telemetry.csv
TELEMETRY_LOGS_ENABLED=true
TELEMETRY_INTERVAL=30
MODEL_PATH=models/
PREDICTION_THRESHOLD=0.7
LOG_LEVEL=INFO
