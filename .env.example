# NeuroShield Configuration
# Copy to .env and update with your values

# ── Jenkins ──────────────────────────────────────
JENKINS_URL=http://localhost:8080
JENKINS_JOB=neuroshield-test-job
# JENKINS_USERNAME=your_jenkins_user
# JENKINS_TOKEN=your_jenkins_api_token

# ── Kubernetes ───────────────────────────────────
K8S_NAMESPACE=neuroshield
AFFECTED_SERVICE=dummy-app
SCALE_REPLICAS=3

# ── Prometheus ───────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── Telemetry ────────────────────────────────────
TELEMETRY_LOGS_ENABLED=true
TELEMETRY_OUTPUT_PATH=data/telemetry.csv
POLL_INTERVAL=10

# ── Prediction ───────────────────────────────────
MODEL_PATH=models/
PREDICTION_THRESHOLD=0.7

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
