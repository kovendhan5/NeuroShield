# NeuroShield Environment Configuration
# Copy this to .env: Copy-Item .env.example .env
# Jenkins runs via Docker: docker compose up -d
# Get API token: http://localhost:8080/user/admin/configure

JENKINS_URL=http://localhost:8080
JENKINS_USERNAME=admin
JENKINS_PASSWORD=your-jenkins-password-here
JENKINS_TOKEN=your-jenkins-api-token-here
JENKINS_JOB=build-pipeline
SELF_CI_JOB=neuroshield-ci
DUMMY_APP_URL=http://localhost:5000
PROMETHEUS_URL=http://localhost:9090
K8S_NAMESPACE=default
AFFECTED_SERVICE=dummy-app
SCALE_REPLICAS=2
POLL_INTERVAL=15
TELEMETRY_OUTPUT_PATH=data/telemetry.csv
TELEMETRY_LOGS_ENABLED=true
TELEMETRY_INTERVAL=30
MODEL_PATH=models/
PREDICTION_THRESHOLD=0.7
LOG_LEVEL=INFO

# ── Email Notifications ──────────────────────────────────────────────────
# NeuroShield sends email alerts for healing actions, escalations, and
# self-CI failures. Uses Gmail SMTP with App Passwords (not regular passwords).
#
# Setup:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Generate an app password for "NeuroShield"
#   3. Paste the 16-character password below (no spaces)
#
# Leave blank to disable email alerts (all notifications fail silently).
ALERT_EMAIL_FROM=your-gmail@gmail.com
ALERT_EMAIL_TO=ops-team@yourcompany.com
ALERT_EMAIL_PASSWORD=your-16-char-app-password

# ─── Slack Notifications ───────────────────────────────────────────────────
# To enable Slack alerts:
# 1. Go to: api.slack.com/apps
# 2. Create new app → "From scratch"
# 3. Add feature: Incoming Webhooks
# 4. Activate webhooks → Add to Workspace
# 5. Choose channel (e.g. #neuroshield-alerts)
# 6. Copy the webhook URL below
# 7. Free Slack workspace works fine
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Application Security ─────────────────────────────────────────────────
# Environment: "development" (default) or "production"
# In production: OpenAPI docs disabled, stricter CORS
NEUROSHIELD_ENV=development

# CORS allowed origins (comma-separated)
# Default: http://localhost:8501,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# Dummy app API key (protects /crash, /stress, /fail endpoints)
DUMMY_APP_API_KEY=
